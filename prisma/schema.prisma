generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"] // ✅ needed for PrismaPg adapter
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id       String @id
  username String @unique
}

model Student {
  id        String   @id
  username  String   @unique
  name      String
  surname   String
  email     String?  @unique
  phone     String?  @unique
  address   String
  img       String?
  bloodType String
  sex       UserSex
  createdAt DateTime @default(now())
  birthday  DateTime

  parentId String
  parent   Parent @relation(fields: [parentId], references: [id])
  classId  Int
  class    Class  @relation(fields: [classId], references: [id])
  gradeId  Int
  grade    Grade  @relation(fields: [gradeId], references: [id])

  attendances Attendance[]
  results     Result[]

  @@index([parentId]) // ✅ speeds up "students by parent" queries
  @@index([classId]) // ✅ speeds up "students in class" queries
  @@index([gradeId])
}

model Teacher {
  id        String   @id
  username  String   @unique
  name      String
  surname   String
  email     String?  @unique
  phone     String?  @unique
  address   String
  img       String?
  bloodType String
  sex       UserSex
  createdAt DateTime @default(now())
  birthday  DateTime

  subjects Subject[]
  notes    Note[]
  lessons  Lesson[]
  classes  Class[]
  exams    Exam[]
}

model Parent {
  id        String   @id
  username  String   @unique
  name      String
  surname   String
  email     String?  @unique
  phone     String   @unique
  address   String
  createdAt DateTime @default(now())

  students Student[]
}

model Grade {
  id    Int @id @default(autoincrement())
  level Int @unique

  students Student[]
  classes  Class[] // ✅ fixed typo: was "classess"
}

model Class {
  id       Int    @id @default(autoincrement())
  name     String @unique
  capacity Int

  supervisorId String?
  supervisor   Teacher? @relation(fields: [supervisorId], references: [id])

  gradeId Int
  grade   Grade @relation(fields: [gradeId], references: [id])

  lessons       Lesson[]
  students      Student[]
  notes         Note[]
  events        Event[]
  announcements Announcement[]
  messages      Message[]
  exams         Exam[]

  @@index([gradeId])
  @@index([supervisorId])
}

model Subject {
  id   Int    @id @default(autoincrement())
  name String @unique

  teachers Teacher[]
  lessons  Lesson[]
  exams    Exam[]
  notes    Note[]

  topics    Topic[]
  questions Question[]
}

model Lesson {
  id        Int      @id @default(autoincrement())
  name      String
  day       Day
  startTime DateTime
  endTime   DateTime

  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id])
  classId   Int
  class     Class   @relation(fields: [classId], references: [id])
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  exams       Exam[]
  assignments Assignment[]
  attendances Attendance[]

  @@index([teacherId]) // ✅ speeds up "lessons by teacher" queries
  @@index([classId])
  @@index([subjectId])
}

model Note {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  fileUrl     String 
  fileType    String 
  isPublic    Boolean @default(false)
  thumbnailUrl String?
  duration    Int?    // seconds — for video/audio
  fileSize    BigInt? // bytes
  tags        String[] // for search
  viewCount   Int     @default(0)

  sourceId  Int?
  source    NoteSource? @relation(fields: [sourceId], references: [id])
  subjectId Int
  subject   Subject  @relation(fields: [subjectId], references: [id])
  classId   Int?
  class     Class?   @relation(fields: [classId], references: [id])
  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  completedBy UserProgress[]
  aiSummary   NoteAISummary?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([subjectId])
  @@index([classId])
  @@index([teacherId])
  @@index([fileType])
  @@index([isPublic])
}

model NoteAISummary {
  id          Int      @id @default(autoincrement())
  noteId      Int      @unique
  note        Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  summary     String   // AI-generated summary
  keyPoints   String[] // bullet points
  difficulty  String   // "beginner" | "intermediate" | "advanced"
  estimatedReadTime Int // minutes
  generatedAt DateTime @default(now())
  model       String   // which AI model generated this
}

model NoteSource {
  id          Int        @id @default(autoincrement())
  name        String     // "Google Drive 1", "YouTube", "Cloudinary", etc.
  type        SourceType
  config      Json       // stores credentials/folder IDs (encrypted at rest)
  isActive    Boolean    @default(true)
  usedBytes   BigInt     @default(0)
  maxBytes    BigInt?    // null = unlimited
  priority    Int        @default(0) // fallback order — lower = preferred
  createdAt   DateTime   @default(now())
  notes       Note[]

  @@index([type])
  @@index([priority])
}

enum SourceType {
  CLOUDINARY
  SUPABASE_STORAGE
  GOOGLE_DRIVE
  YOUTUBE
  EXTERNAL_URL
}


model UserProgress {
  id           Int      @id @default(autoincrement())
  userId       String
  noteId       Int
  note         Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  isLearned    Boolean  @default(false)
  lastRead     DateTime @default(now())
  timeSpent    Int      @default(0)  // seconds
  progress     Int      @default(0)  // 0-100 percentage (for video/PDF scroll)
  sessionCount Int      @default(0)  // how many times opened

  @@unique([userId, noteId])
  @@index([userId])
  @@index([noteId])
}

model Exam {
  id          Int            @id @default(autoincrement())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  duration    Int?
  visibility  ExamVisibility @default(PRIVATE)
  lessonId    Int?
  lesson      Lesson?        @relation(fields: [lessonId], references: [id])
  subjectId   Int?
  subject     Subject?       @relation(fields: [subjectId], references: [id])
  classId     Int?
  class       Class?         @relation(fields: [classId], references: [id])
  questions   ExamQuestion[]
  resources   ExamResource[]
  results     Result[]
  teacherId   String?
  teacher     Teacher?       @relation(fields: [teacherId], references: [id])

  requiresProctoring Boolean @default(false)
  shuffleQuestions   Boolean @default(true)
  shuffleChoices     Boolean @default(true)
  showResults        Boolean @default(false)
  passingScore       Int     @default(50)
  maxAttempts        Int     @default(1)
  isPublic           Boolean @default(false)

  @@index([lessonId])
  @@index([visibility])
}

model Topic {
  id        Int        @id @default(autoincrement())
  name      String
  subjectId Int
  subject   Subject    @relation(fields: [subjectId], references: [id])
  subTopics SubTopic[]
  questions Question[]

  @@index([subjectId])
}

model SubTopic {
  id        Int        @id @default(autoincrement())
  name      String
  topicId   Int
  topic     Topic      @relation(fields: [topicId], references: [id])
  questions Question[]

  @@index([topicId])
}

model Question {
  id            Int            @id @default(autoincrement())
  content       String // markdown supported
  type          QuestionType
  marks         Int            @default(1)
  explanation   String? // markdown — shown after exam
  imageUrl      String?
  subjectId     Int
  subject       Subject        @relation(fields: [subjectId], references: [id])
  topicId       Int?
  topic         Topic?         @relation(fields: [topicId], references: [id])
  subTopicId    Int?
  subTopic      SubTopic?      @relation(fields: [subTopicId], references: [id])
  choices       Choice[]
  examQuestions ExamQuestion[]
  createdAt     DateTime       @default(now())
  createdById   String // teacher/admin clerk id

  @@index([subjectId])
  @@index([topicId])
  @@index([subTopicId])
}

model Choice {
  id         Int      @id @default(autoincrement())
  content    String // markdown supported
  isCorrect  Boolean  @default(false)
  imageUrl   String?
  questionId Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model ExamQuestion {
  id         Int      @id @default(autoincrement())
  examId     Int
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionId Int
  question   Question @relation(fields: [questionId], references: [id])
  order      Int
  marks      Int // can override question default marks

  @@unique([examId, questionId])
  @@index([examId])
}

model ExamResource {
  id        Int      @id @default(autoincrement())
  examId    Int
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  name      String
  url       String
  type      String // 'pdf' | 'docx' | 'pptx' | 'image' | 'video'
  size      Int // bytes
  createdAt DateTime @default(now())

  @@index([examId])
}

enum QuestionType {
  MULTIPLE_CHOICE
  MULTIPLE_SELECT
  TRUE_FALSE
  SHORT_ANSWER
  LONG_ANSWER
  FILL_BLANK
  MATCHING
}

enum ExamVisibility {
  PRIVATE
  PUBLIC
  CLASS_ONLY
}

model Assignment {
  id        Int      @id @default(autoincrement())
  title     String
  startDate DateTime @default(now())
  dueDate   DateTime

  lessonId Int
  lesson   Lesson @relation(fields: [lessonId], references: [id])

  results Result[]

  @@index([lessonId])
}

model Result {
  id        Int      @id @default(autoincrement())
  score     Int
  createdAt DateTime @default(now())
  remarks   String?

  examId       Int?
  exam         Exam?       @relation(fields: [examId], references: [id])
  assignmentId Int?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      Student     @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([examId])
  @@index([assignmentId])
}

model Attendance {
  id      Int      @id @default(autoincrement())
  date    DateTime
  present Boolean

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  lessonId  Int
  lesson    Lesson  @relation(fields: [lessonId], references: [id])

  @@index([studentId])
  @@index([lessonId])
  @@index([date]) // ✅ speeds up date-range attendance queries
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  startTime   DateTime
  endTime     DateTime

  classId Int?
  class   Class? @relation(fields: [classId], references: [id])

  @@index([classId])
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  date        DateTime

  classId Int?
  class   Class? @relation(fields: [classId], references: [id])

  @@index([classId])
  @@index([date])
}

model Message {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())

  senderId String

  receiverId String

  classId Int?
  class   Class? @relation(fields: [classId], references: [id])

  @@index([senderId])
  @@index([receiverId])
}

enum UserSex {
  MALE
  FEMALE
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}
